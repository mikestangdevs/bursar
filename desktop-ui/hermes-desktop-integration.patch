     animation: none;
   }
 }
+
+/*
+ * Bursar lens accent. Scoped to `.bursar` (the lens shell root), so it never
+ * repaints the host chat UI. We deliberately retint only the shadcn "primary"
+ * + focus ring (CTAs, active nav, chart series) to an exchange-floor emerald
+ * and add gain/loss/warn semantics — neutrals stay Hermes-neutral, matching
+ * the "extend Hermes neutral + a Bursar accent" direction. Works in light and
+ * dark because only absolute accent colors are overridden; the neutral palette
+ * keeps deriving from the host theme.
+ */
+.bursar {
+  --bursar-accent: #0e9f6e;
+  --bursar-accent-strong: #0b8a5f;
+  --bursar-gain: #16a34a;
+  --bursar-loss: #e5484d;
+  --bursar-warn: #d97706;
+  --bursar-queued: #6366f1;
+
+  --dt-primary: var(--bursar-accent);
+  --dt-primary-foreground: #f6fefb;
+  --dt-ring: var(--bursar-accent);
+}
+
+.dark .bursar,
+.bursar.dark {
+  --bursar-accent: #1bbd84;
+  --bursar-accent-strong: #15a874;
+  --bursar-gain: #2bbf6a;
+  --bursar-loss: #ef5b5f;
+  --bursar-warn: #e0913a;
+  --bursar-queued: #818cf8;
+}
